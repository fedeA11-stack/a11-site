# Contact form email delivery (app/contact/actions.ts).
# Copy to .env.local and fill in. Without RESEND_API_KEY the form shows a
# graceful fallback ("email hello@a11.studio directly") instead of sending.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Where contact submissions are delivered. Defaults to hello@a11.studio.
CONTACT_TO=hello@a11.studio

# Verified Resend sender. The domain (a11.studio) must be verified in Resend
# with SPF/DKIM DNS records before mail will deliver from this address.
CONTACT_FROM="A11 Contact <noreply@a11.studio>"
